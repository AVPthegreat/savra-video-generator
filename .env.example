GEMINI_API_KEY=your_key_here
SVG_ASSETS_DIR=../assets/svgs
MAX_SCENES=15
MAX_INPUT_CHARS=200000
MAX_UPLOAD_MB=20
GEMINI_MODEL=gemini-2.5-flash
OUTPUT_DIR=../renderer/public
RUN_RETENTION_COUNT=20

APP_ENV=development
AUTO_CREATE_TABLES=true
RECOVER_STALE_JOBS_ON_STARTUP=true
DATABASE_SSL_MODE=prefer
JOB_WORKER_COUNT=2
JOB_QUEUE_CAPACITY=6
MAX_CONCURRENT_RENDERS=1

ENABLE_AUTH=false
AUTH_USERNAME=admin
AUTH_PASSWORD=change_me
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Local default (SQLite)
DATABASE_URL=sqlite:///./savra.db

# Docker/Postgres deployment values
POSTGRES_USER=savra
POSTGRES_PASSWORD=change_me
POSTGRES_DB=savradevdb
# DATABASE_URL=postgresql://savra:change_me@db:5432/savradevdb

# Multi-Model Animation Director
# Provider fallback order: Groq (primary) → Cerebras → Gemini (GEMINI_API_KEY above)
USE_MULTI_MODEL_DIRECTOR=false
GROQ_API_KEY=
CEREBRAS_API_KEY=

# Semantic Asset Pipeline (Phase 3)
ASSET_INDEX_PATH=assets/index.json
ASSET_UNDRAW_DIR=assets/undraw/svg
ASSET_CACHE_DIR=/tmp/iconify_cache
SEMANTIC_THRESHOLD=0.30
GCS_ASSETS_BUCKET=gs://savra-video-assets