# Copy to .env for production deployment.
# Set all placeholder values before running docker compose.

GEMINI_API_KEY=replace_with_real_key
GEMINI_MODEL=gemini-2.5-flash
SVG_ASSETS_DIR=../assets/svgs
OUTPUT_DIR=../renderer/public
RUN_RETENTION_COUNT=20
MAX_SCENES=15
MAX_INPUT_CHARS=200000
MAX_UPLOAD_MB=20

APP_ENV=production
AUTO_CREATE_TABLES=false
RECOVER_STALE_JOBS_ON_STARTUP=true
DATABASE_SSL_MODE=require
JOB_WORKER_COUNT=2
JOB_QUEUE_CAPACITY=6
MAX_CONCURRENT_RENDERS=1

ENABLE_AUTH=true
AUTH_USERNAME=replace_admin_username
AUTH_PASSWORD=replace_with_strong_password
JWT_SECRET=replace_with_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

POSTGRES_USER=savra
POSTGRES_PASSWORD=replace_with_strong_db_password
POSTGRES_DB=savradevdb
DATABASE_URL=postgresql://savra:replace_with_strong_db_password@db:5432/savradevdb
